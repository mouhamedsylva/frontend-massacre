                  <button class="tool-btn" id="btn-text-align-right" title="Droite" type="button">▧</button>
                </div>
              </div> {% endcomment %}

              <!-- Slider masqué pour compatibilité JS -->
              <input type="range" id="text-size-slider" style="display:none;" min="10" max="200" value="48">


            <span class="btn-icon">🎨</span>
            <span class="btn-label">Arts</span>
          </button>
          <button class="nav-icon-btn" data-tab="tab-shapes" type="button" title="Formes">
            <span class="btn-icon">🔷</span>
            <span class="btn-label">Formes</span>
          </button>
          <button class="nav-icon-btn" data-tab="tab-colors" type="button" title="Couleurs">
            <span class="btn-icon">🎨</span>
            <span class="btn-label">Couleurs</span>
          </button>
        </div>

        <!-- Panneau de contenu de l'onglet actif -->
        <div class="sidebar-tabs-content">
          
          <!-- 1. Onglet UPLOAD -->
          <div class="tab-panel active" id="tab-upload">
            
            <div class="upload-zone-wrapper">
              <div class="upload-zone" id="upload-zone">
                <input type="file" 
                       id="image-upload-input" 
                       accept="image/png,image/jpeg,image/jpg"
                       style="display: none;">
                
                <label for="image-upload-input" class="upload-label">
                  <svg class="upload-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                  </svg>
                  <span class="upload-text">Cliquez ou glissez-déposez</span>
                  <span class="upload-hint">PNG ou JPEG, max 5 Mo</span>
                </label>
              </div>
            </div>

            <div class="tab-actions-group" style="margin-top: 1.5rem;">
              <h4 class="sub-tab-title">Actions sur l'élément</h4>
              <button class="btn btn-secondary btn-full" id="btn-delete-selected" type="button" disabled style="margin-bottom: 0.5rem;">
                🗑️ Supprimer la sélection
              </button>
              <button class="btn btn-secondary btn-full" id="btn-clear-view" type="button">
                🧹 Effacer cette vue
              </button>
            </div>
          </div>

          <!-- 2. Onglet TEXTE (Style CustomInk) -->
          <div class="tab-panel" id="tab-text">
            
            <!-- Zone d'écriture type CustomInk -->
            <div class="customink-text-entry">
              <label class="form-label">Entrez votre texte ici :</label>
              <textarea id="text-input" class="customink-textarea" placeholder="Tapez votre texte...">papa</textarea>
              <button class="btn btn-primary btn-full" id="btn-add-text" type="button">
                ➕ Ajouter au design
              </button>
            </div>

            <!-- Panneau de contrôle des options -->
            <div class="text-controls-panel">
              
              <!-- 1. Font Selection -->
              <div class="control-row">
                <label class="control-label">Police d'écriture</label>
                <div class="font-selector-wrapper">
                  <select id="text-font" class="font-select">
                    <option value="Arial" selected>Arial</option>
                    <option value="Helvetica">Helvetica</option>
                    <option value="Times New Roman">Times New Roman</option>
                    <option value="Georgia">Georgia</option>
                    <option value="Verdana">Verdana</option>
                    <option value="Impact">Impact</option>
                    <option value="Comic Sans MS">Comic Sans MS</option>
                    <option value="Brush Script MT">Brush Script MT</option>
                  </select>
                </div>
              </div>

              <!-- 2. Color Selection (Palette compacte) -->
              <div class="control-row">
                <label class="control-label">Couleur du texte</label>
                <div class="compact-palette" id="text-color-palette">
                  <button class="palette-color active" data-color="#000000" style="background: #000000;" title="Noir" type="button"></button>
                  <button class="palette-color" data-color="#FFFFFF" style="background: #FFFFFF; border: 1px solid #ddd;" title="Blanc" type="button"></button>
                  <button class="palette-color" data-color="#FF0000" style="background: #FF0000;" title="Rouge" type="button"></button>
                  <button class="palette-color" data-color="#0000FF" style="background: #0000FF;" title="Bleu" type="button"></button>
                  <button class="palette-color" data-color="#008000" style="background: #008000;" title="Vert" type="button"></button>
                  <button class="palette-color" data-color="#FFFF00" style="background: #FFFF00;" title="Jaune" type="button"></button>
                  <button class="palette-color" data-color="#FFA500" style="background: #FFA500;" title="Orange" type="button"></button>
                  <button class="palette-color" data-color="#800080" style="background: #800080;" title="Violet" type="button"></button>
                </div>
              </div>

              <!-- 3. Size & Rotation -->
              <div class="control-grid-2">
                <div class="control-row">
                  <label class="control-label">Taille</label>
                  <div class="input-with-unit">
                    <input type="number" id="text-size-value" value="48" min="10" max="200">
                    <span>px</span>
                  </div>
                </div>
                <div class="control-row">
                  <label class="control-label">Rotation</label>
                  <div class="input-with-unit">
                    <input type="number" id="text-rotation-value" value="0" min="-180" max="180">
                    <span>°</span>
                  </div>
                </div>
              </div>

              <!-- Slider de secours (masqué mais utilisé par le script) -->
              <input type="range" id="text-size-slider" style="display:none;" min="10" max="200" value="48">
              <input type="range" id="text-rotation-slider" style="display:none;" min="-180" max="180" value="0">

              <!-- 4. Style (B, I, U) + Alignement -->
              <div class="control-row">
                <label class="control-label">Style & Alignement</label>
                <div class="toolbar-group">
                  <div class="btn-group">
                    <button class="tool-btn" id="btn-text-bold" title="Gras" type="button"><b>B</b></button>
                    <button class="tool-btn" id="btn-text-italic" title="Italique" type="button"><i>I</i></button>
                  </div>
                  <div class="btn-group">

                🧹 Effacer cette vue
              </button>
            </div>
          </div>

          <!-- 2. Onglet TEXTE -->
          <div class="tab-panel" id="tab-text">

            <!-- ÉTAT 1 : Saisie initiale (visible par défaut) -->
            <div id="text-add-section">
              <input
                type="text"
                id="text-input"
                class="text-add-input"
                placeholder="Saisir votre texte ici"
              />
              <button class="btn btn-primary btn-full" id="btn-add-text" type="button">
                Ajouter au Design
              </button>
            </div>

            <!-- ÉTAT 2 : Options d'édition (masqué jusqu'à sélection d'un texte) -->

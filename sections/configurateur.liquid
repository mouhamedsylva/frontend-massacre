                <button class="color-btn" data-color="#A1887F" style="background: #A1887F;" title="Taupe"></button>
                <button class="color-btn" data-color="#BCAAA4" style="background: #BCAAA4;" title="Beige"></button>
                <button class="color-btn" data-color="#D7CCC8" style="background: #D7CCC8;" title="Beige clair"></button>
                <button class="color-btn" data-color="#F5F5DC" style="background: #F5F5DC;" title="Beige ivoire"></button>
                <button class="color-btn" data-color="#FFF8DC" style="background: #FFF8DC;" title="Crème"></button>
              </div>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
              <button class="btn btn-secondary btn-full" id="btn-reset-product-color" type="button">
                ↻ Réinitialiser la couleur
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- CENTRE : Espace de travail du Canvas -->
      <div class="canvas-workspace">
        
        <!-- Boutons Undo/Redo flottants (style Custom Ink) -->
        <div class="undo-redo-buttons">
          <button class="history-btn" id="btn-undo" type="button" title="Annuler (Ctrl+Z)" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 7v6h6"></path>
              <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"></path>
            </svg>
            <span class="history-label">Undo</span>
          </button>
          <button class="history-btn" id="btn-redo" type="button" title="Refaire (Ctrl+Y)" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 7v6h-6"></path>
              <path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"></path>
            </svg>
            <span class="history-label">Redo</span>
          </button>
        </div>

        <div class="canvas-wrapper">
          <canvas id="customization-canvas"></canvas>
          <div class="canvas-loader" id="canvas-loader" style="display: none;">
            <div class="spinner"></div>
            <p>Chargement...</p>
          </div>
        </div>
        
        <!-- DROITE : Sélecteur de vues flottant avec vignettes -->
        <div class="floating-view-selector">
          <button class="view-thumbnail-btn active" data-view="front" type="button" id="btn-view-front">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-front" src="" alt="Face" width="200" height="200">
            </div>
            <span class="thumbnail-label">Face</span>
          </button>
          <button class="view-thumbnail-btn" data-view="back" type="button" id="btn-view-back">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-back" src="" alt="Dos" width="200" height="200">
            </div>
            <span class="thumbnail-label">Dos</span>
          </button>
          <button class="view-thumbnail-btn" data-view="left" type="button" id="btn-view-left">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-left" src="" alt="Gauche" width="200" height="200">
            </div>
            <span class="thumbnail-label">Gauche</span>
          </button>
          <button class="view-thumbnail-btn" data-view="right" type="button" id="btn-view-right">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-right" src="" alt="Droite" width="200" height="200">
            </div>
            <span class="thumbnail-label">Droite</span>
          </button>
        </div>
      </div>

    </div>

    <!-- Bouton d'action principal (Preview & Submit) -->
    <div class="main-actions-bar">
      <button class="btn btn-preview" id="btn-preview-design" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        Aperçu du Design
      </button>
      <button class="btn btn-primary btn-submit" id="btn-submit-design" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        Envoyer le Design
      </button>
    </div>

    <!-- Modal de Preview -->
    <div class="preview-modal" id="preview-modal" style="display: none;">
      <div class="preview-modal-overlay" id="preview-modal-overlay"></div>
      <div class="preview-modal-content">
        <div class="preview-modal-header">
          <h2 class="preview-modal-title">Aperçu de votre Design</h2>
          <button class="preview-modal-close" id="btn-close-preview" type="button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        
        <div class="preview-modal-body">
          <div class="preview-views-grid">
            <div class="preview-view-item">
              <h3 class="preview-view-label">Face</h3>
              <div class="preview-image-container">
                <img id="preview-img-front" src="" alt="Face" class="preview-image">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Dos</h3>
              <div class="preview-image-container">
                <img id="preview-img-back" src="" alt="Dos" class="preview-image">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Côté Gauche</h3>
              <div class="preview-image-container">
                <img id="preview-img-left" src="" alt="Gauche" class="preview-image">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Côté Droit</h3>
              <div class="preview-image-container">
                <img id="preview-img-right" src="" alt="Droite" class="preview-image">
              </div>
            </div>
          </div>
        </div>
        
        <div class="preview-modal-footer">
          <button class="btn btn-secondary" id="btn-continue-editing" type="button">
            Continuer l'édition
          </button>
          <button class="btn btn-primary btn-large" id="btn-confirm-submit" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Confirmer et Envoyer
          </button>
        </div>
      </div>
    </div>

    <script>
      window.CONFIGURATEUR_CONFIG = {
        apiEndpoint: {{ settings.microservice_api_url | json }},
        debugMode: {{ settings.enable_debug_mode | json }}
      };
    </script>
  </section>

</div>

{% schema %}
{
  "name": "Configurateur",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "Titre principal",
      "default": "Créez votre produit personnalisé"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sélectionnez un produit et uploadez votre design sur les différentes faces."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produit personnalisable",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit Shopify"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Configurateur",
      "blocks": []
    }
  ]
}
{% endschema %}

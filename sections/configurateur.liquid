              <input type="text" id="text-input-edit" class="text-add-input"
                placeholder="Modifier le texte" style="margin-bottom: 1.2rem;" />

              <!-- Changer le font -->
              <div class="text-edit-row">
                <span class="text-edit-label">Changer le font</span>
                <button id="btn-open-font-picker" type="button" class="text-edit-select text-font-trigger">
                  <span id="font-picker-label">Arial</span>
                  <span style="margin-left: auto; font-size: 0.7rem; color: #888;">▼</span>
                </button>
              </div>

              <!-- Panneau de sélection de police (masqué par défaut) -->
              <div id="font-picker-panel" style="display: none; margin-top: 0.5rem; background: #fff; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.15); position: relative; z-index: 100;">
                <!-- Header -->
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; border-bottom: 1px solid #eee;">
                  <button id="btn-font-back" type="button" style="background:none; border:none; cursor:pointer; font-size: 1rem; color:#333;">‹</button>
                  <span style="font-weight: 600; font-size: 0.9rem;">Polices</span>
                  <button id="btn-font-close" type="button" style="background:none; border:none; cursor:pointer; font-size: 1.1rem; color:#333;">✕</button>
                </div>
                <!-- Recherche -->
                <div style="padding: 0.6rem 1rem; border-bottom: 1px solid #eee;">
                  <input id="font-search-input" type="text" placeholder="Rechercher une police..." 
                        style="width: 100%; padding: 0.4rem 0.6rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.85rem; box-sizing: border-box;" />
                </div>
                <!-- Liste avec aperçu -->
                <div id="font-picker-list" style="max-height: 320px; overflow-y: auto;"></div>
              </div>

              <!-- Éditer la couleur -->
              <div class="text-edit-row">
                <span class="text-edit-label">Éditer la couleur</span>
                <div class="text-color-row">
                  <span id="text-color-label">Noir</span>
                  <input type="color" id="text-color-picker" value="#000000" class="text-color-picker">
                </div>
              </div>

              <!-- Rotation -->
              <div class="text-edit-row">
                <span class="text-edit-label">Rotation</span>
                <div class="text-rotation-row">
                  <input type="range" id="text-rotation-slider" min="0" max="360" value="0" class="text-rotation-slider">
                  <input type="number" id="text-rotation-value" value="0" min="0" max="360" class="text-rotation-num">
                </div>
              </div>

              <!-- Contour -->
              <div class="text-edit-row text-edit-row--toggle" id="text-outline-toggle">
                <span class="text-edit-label">Contour</span>
                <span class="text-edit-expand">sélectionner le contour ›</span>
              </div>
              <div id="text-outline-options" class="text-expand-panel" style="display: none;">
                <div class="text-expand-inner">
                  <label class="text-expand-sublabel">Couleur</label>
                  <select id="text-outline-color" class="text-edit-select">
                    <option value="none">Aucun</option>
                    <option value="#000000">Noir</option>
                    <option value="#ffffff">Blanc</option>
                    <option value="#FF0000">Rouge</option>
                    <option value="#0000FF">Bleu</option>
                    <option value="#FFFF00">Jaune</option>
                    <option value="#FFA500">Orange</option>
                  </select>
                  <label class="text-expand-sublabel" style="margin-top: 0.5rem;">Épaisseur</label>
                  <input type="range" id="text-outline-width" min="0" max="10" value="0" class="text-rotation-slider">
                </div>
              </div>

              <!-- Forme du texte -->
              <div class="text-edit-row text-edit-row--toggle" id="text-shape-toggle">
                <span class="text-edit-label">Forme du texte</span>
                <span class="text-edit-expand">sélectionner la forme ›</span>
              </div>
              <div id="text-shape-options" class="text-expand-panel" style="display: none;">
                <!-- Rempli dynamiquement par text-shape-warp.js -->
              </div>

              <!-- Taille du texte -->
              <div class="text-edit-row">
                <span class="text-edit-label">Taille du texte</span>
                <div class="input-with-unit" style="width: 80px;">
                  <input type="number" id="text-size-value" min="8" max="200" value="40">
                  <span>px</span>
                </div>
              </div>

              {% comment %} <!-- Centrer -->

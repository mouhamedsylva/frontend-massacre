                <circle cx="9" cy="10" r="1.2" fill="currentColor"></circle>
                <circle cx="15" cy="9" r="1.2" fill="currentColor"></circle>
                <path d="M8 14c1.2 1.6 2.6 2.4 4 2.4s2.8-.8 4-2.4"></path>
              </svg>
            </span>
            <span class="btn-label">Arts</span>
          </button>

          {% comment %} <button class="nav-icon-btn" data-tab="tab-shapes" type="button" title="Formes">
            <span class="btn-icon">

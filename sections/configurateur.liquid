                <line x1="9" y1="20" x2="15" y2="20"></line>
                <line x1="12" y1="4" x2="12" y2="20"></line>
              </svg>
            </span>
            <span class="btn-label">Texte</span>
          </button>

          <button class="nav-icon-btn" data-tab="tab-cliparts" type="button" title="Cliparts">

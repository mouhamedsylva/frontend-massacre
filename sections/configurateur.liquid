                <button class="color-btn" data-color="#AD1457" style="background: #AD1457;" title="Magenta foncé"></button>
                <button class="color-btn" data-color="#880E4F" style="background: #880E4F;" title="Rose pourpre"></button>
                <button class="color-btn" data-color="#6A1B9A" style="background: #6A1B9A;" title="Violet foncé"></button>
                <button class="color-btn" data-color="#4A148C" style="background: #4A148C;" title="Pourpre foncé"></button>
                
                <!-- Violets -->
                <button class="color-btn" data-color="#512DA8" style="background: #512DA8;" title="Violet"></button>
                <button class="color-btn" data-color="#673AB7" style="background: #673AB7;" title="Violet profond"></button>
                <button class="color-btn" data-color="#7E57C2" style="background: #7E57C2;" title="Violet moyen"></button>
                <button class="color-btn" data-color="#9575CD" style="background: #9575CD;" title="Violet clair"></button>
                <button class="color-btn" data-color="#B39DDB" style="background: #B39DDB;" title="Lilas"></button>
                <button class="color-btn" data-color="#D1C4E9" style="background: #D1C4E9;" title="Lilas clair"></button>
                <button class="color-btn" data-color="#BA68C8" style="background: #BA68C8;" title="Orchidée"></button>
                <button class="color-btn" data-color="#CE93D8" style="background: #CE93D8;" title="Rose violet"></button>
                <button class="color-btn" data-color="#F48FB1" style="background: #F48FB1;" title="Rose"></button>
                <button class="color-btn" data-color="#F06292" style="background: #F06292;" title="Rose vif"></button>
                
                <!-- Beiges & Taupes -->
                <button class="color-btn" data-color="#EFEBE9" style="background: #EFEBE9;" title="Beige très clair"></button>
                <button class="color-btn" data-color="#4E342E" style="background: #4E342E;" title="Brun foncé"></button>
                <button class="color-btn" data-color="#A1887F" style="background: #A1887F;" title="Taupe"></button>
                <button class="color-btn" data-color="#BCAAA4" style="background: #BCAAA4;" title="Beige"></button>
                <button class="color-btn" data-color="#D7CCC8" style="background: #D7CCC8;" title="Beige clair"></button>
                <button class="color-btn" data-color="#F5F5DC" style="background: #F5F5DC;" title="Beige ivoire"></button>
                <button class="color-btn" data-color="#FFF8DC" style="background: #FFF8DC;" title="Crème"></button>
              </div>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
              <button class="btn btn-secondary btn-full" id="btn-reset-product-color" type="button">
                ↻ Réinitialiser la couleur
              </button>
            </div>
          </div>

        </div>


      </div>

      <!-- CENTRE : Espace de travail du Canvas -->
      <div class="canvas-workspace">
        
        <!-- Boutons Undo/Redo flottants (style Custom Ink) -->
        <div class="undo-redo-buttons">
          <button class="history-btn" id="btn-undo" type="button" title="Annuler (Ctrl+Z)" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 7v6h6"></path>
              <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"></path>
            </svg>
            <span class="history-label">Undo</span>
          </button>
          <button class="history-btn" id="btn-redo" type="button" title="Refaire (Ctrl+Y)" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 7v6h-6"></path>
              <path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"></path>
            </svg>
            <span class="history-label">Redo</span>
          </button>
        </div>

        <!-- CONTRÔLE D'OPACITÉ FLOTTANT (apparaît seulement quand un objet est sélectionné) -->
        <div id="panel-opacity" class="floating-opacity-control" style="display: none;">
          <span class="opacity-icon">🔍</span>
          <span class="opacity-label">Opacité</span>
          <input type="range" id="global-opacity-slider" min="0" max="100" value="100" class="opacity-slider">
          <input type="number" id="global-opacity-value" value="100" min="0" max="100" class="opacity-number">
          <span class="opacity-percent">%</span>
        </div>

        <div class="canvas-wrapper">
          <canvas id="customization-canvas"></canvas>
          <div class="canvas-loader" id="canvas-loader" style="display: none;">
            <div class="spinner"></div>
            <p>Chargement...</p>
          </div>
        </div>


        <!-- Boutons Zoom flottants -->
        <div class="zoom-controls">
          <button class="zoom-btn" id="btn-zoom-out" type="button" title="Dézoomer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
          </button>
          <span class="zoom-level" id="zoom-level-label">100%</span>
          <button class="zoom-btn" id="btn-zoom-in" type="button" title="Zoomer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="11" y1="8" x2="11" y2="14"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
          </button>
          <button class="zoom-btn zoom-reset" id="btn-zoom-reset" type="button" title="Réinitialiser le zoom">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 7v6h6"></path>
              <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"></path>
            </svg>
          </button>
        </div>
        
        <!-- DROITE : Sélecteur de vues flottant avec vignettes -->
        <div class="floating-view-selector">
          <button class="view-thumbnail-btn active" data-view="front" type="button" id="btn-view-front">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-front" src="" alt="Face" width="200" height="200">
            </div>
            <span class="thumbnail-label">Face</span>
          </button>
          <button class="view-thumbnail-btn" data-view="back" type="button" id="btn-view-back">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-back" src="" alt="Dos" width="200" height="200">
            </div>
            <span class="thumbnail-label">Dos</span>
          </button>
          <button class="view-thumbnail-btn" data-view="left" type="button" id="btn-view-left">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-left" src="" alt="Gauche" width="200" height="200">
            </div>
            <span class="thumbnail-label">Gauche</span>
          </button>
          <button class="view-thumbnail-btn" data-view="right" type="button" id="btn-view-right">
            <div class="thumbnail-img-container">
              <img id="view-thumbnail-right" src="" alt="Droite" width="200" height="200">
            </div>
            <span class="thumbnail-label">Droite</span>
          </button>
        </div>
      </div>

    </div>

    <!-- Bouton d'action principal (Preview & Submit) -->
    <div class="main-actions-bar">
      <button class="btn btn-preview" id="btn-preview-design" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        Aperçu du Design
      </button>
      <button class="btn btn-primary btn-submit" id="btn-submit-design" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        Envoyer le Design
      </button>
    </div>

    <!-- Modal de Preview -->
    <div class="preview-modal" id="preview-modal" style="display: none;">
      <div class="preview-modal-overlay" id="preview-modal-overlay"></div>
      <div class="preview-modal-content">
        <div class="preview-modal-header">
          <h2 class="preview-modal-title">Aperçu de votre Design</h2>
          <button class="preview-modal-close" id="btn-close-preview" type="button">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        
        <div class="preview-modal-body">
          <div class="preview-views-grid">
            <div class="preview-view-item">
              <h3 class="preview-view-label">Face</h3>
              <div class="preview-image-container">
                <img id="preview-img-front" src="" alt="Face" class="preview-image" width="200" height="200">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Dos</h3>
              <div class="preview-image-container">
                <img id="preview-img-back" src="" alt="Dos" class="preview-image" width="200" height="200">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Côté Gauche</h3>
              <div class="preview-image-container">
                <img id="preview-img-left" src="" alt="Gauche" class="preview-image" width="200" height="200">
              </div>
            </div>
            <div class="preview-view-item">
              <h3 class="preview-view-label">Côté Droit</h3>
              <div class="preview-image-container">
                <img id="preview-img-right" src="" alt="Droite" class="preview-image" width="200" height="200">
              </div>
            </div>
          </div>
        </div>
        
        <div class="preview-modal-footer">
          <button class="btn btn-secondary" id="btn-continue-editing" type="button">
            Continuer l'édition
          </button>
          <button class="btn btn-primary btn-large" id="btn-confirm-submit" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            Confirmer et Envoyer
          </button>
        </div>
      </div>
    </div>

    <!-- Modal Formulaire Client -->
    <div class="customer-form-modal" id="customer-form-modal" style="display: none;">
      <div class="customer-form-overlay" id="customer-form-overlay"></div>
      <div class="customer-form-content">
        <div class="customer-form-header">
          <h2 class="customer-form-title">📋 Vos Informations</h2>
          <p class="customer-form-subtitle">Complétez ce formulaire pour recevoir votre devis personnalisé</p>
          <button class="customer-form-close" id="btn-close-customer-form" type="button" aria-label="Fermer">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        
        <form id="customer-info-form" class="customer-info-form">
          <div class="form-grid">
            <!-- Prénom -->
            <div class="form-field">
              <label for="customer-first-name" class="form-field-label">
                Prénom <span class="required">*</span>
              </label>
              <input 
                type="text" 
                id="customer-first-name" 
                name="first_name" 
                class="form-field-input"
                placeholder="ex: Jean"
                required
                autocomplete="given-name"
              >
            </div>

            <!-- Nom -->
            <div class="form-field">
              <label for="customer-last-name" class="form-field-label">
                Nom <span class="required">*</span>
              </label>
              <input 
                type="text" 
                id="customer-last-name" 
                name="last_name" 
                class="form-field-input"
                placeholder="ex: Dupont"
                required
                autocomplete="family-name"
              >
            </div>
          </div>

          <!-- Email -->
          <div class="form-field">
            <label for="customer-email" class="form-field-label">
              Adresse Email <span class="required">*</span>
            </label>
            <input 
              type="email" 
              id="customer-email" 
              name="email" 
              class="form-field-input"
              placeholder="ex: jean.dupont@email.com"
              required
              autocomplete="email"
            >
            <p class="form-field-hint">📧 Nous vous enverrons votre devis à cette adresse</p>
          </div>

          <!-- Téléphone (optionnel) -->
          <div class="form-field">
            <label for="customer-phone" class="form-field-label">
              Téléphone <span class="optional">(optionnel)</span>
            </label>
            <input 
              type="tel" 
              id="customer-phone" 
              name="phone" 
              class="form-field-input"
              placeholder="ex: +33 6 12 34 56 78"
              autocomplete="tel"
            >
            <p class="form-field-hint">📱 Pour un suivi plus rapide de votre commande</p>
          </div>

          <!-- Message complémentaire (optionnel) -->
          <div class="form-field">
            <label for="customer-message" class="form-field-label">
              Message ou Instructions <span class="optional">(optionnel)</span>
            </label>
            <textarea 
              id="customer-message" 
              name="message" 
              class="form-field-textarea"
              placeholder="Des précisions sur votre commande ? Des questions ?"
              rows="4"
            ></textarea>
          </div>

          <!-- Boutons -->
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('btn-close-customer-form').click()">
              ← Retour
            </button>
            <button type="submit" class="btn btn-primary btn-large">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              Envoyer mon Design
            </button>
          </div>

          <p class="form-footer-note">
            🔒 Vos données sont sécurisées et ne seront utilisées que pour traiter votre demande
          </p>
        </form>
      </div>
    </div>

  </section>

</div>

{% schema %}
{
  "name": "Configurateur",
  "settings": [
    {
      "type": "text",
      "id": "main_title",
      "label": "Titre principal",
      "default": "Créez votre produit personnalisé"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sélectionnez un produit et uploadez votre design sur les différentes faces."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produit personnalisable",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit Shopify"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Configurateur",
      "blocks": []
    }
  ]
}
{% endschema %}

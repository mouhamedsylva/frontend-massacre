                    <button class="tool-btn" id="btn-text-align-center" title="Centre" type="button">▥</button>
                    <button class="tool-btn" id="btn-text-align-right" title="Droite" type="button">▧</button>
                  </div>
                </div>
              </div>

              <!-- 5. Actions rapides -->
              <div class="control-row">
                <div class="quick-actions">
                  <button class="btn btn-secondary btn-sm" id="btn-text-center" type="button">🎯 Centrer</button>
                  <button class="btn btn-secondary btn-sm" id="btn-text-duplicate" type="button">👯 Dupliquer</button>
                </div>
              </div>

            </div>
          </div>

          <!-- 3. Onglet MOTIFS -->

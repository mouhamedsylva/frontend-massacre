{% comment %}
  Section : configurateur.liquid
  Section principale du module de customisation multi-vues
  
  Metafields utilisés pour chaque produit :
  - product.metafields.custom.image_front : Image de la vue Face
  - product.metafields.custom.image_back : Image de la vue Dos
  - product.metafields.custom.image_left : Image de la vue Gauche
  - product.metafields.custom.image_right : Image de la vue Droite
  - product.metafields.custom.editable_zones : JSON avec les coordonnées des zones éditables
{% endcomment %}

<script>
  // Configuration de l'URL du backend Railway
  window.CONFIGURATEUR_CONFIG = {
    apiEndpoint: 'https://backend-massacre-production.up.railway.app/submit-devis',
    debugMode: false
  };
</script>

{{ 'configurateur.css' | asset_url | stylesheet_tag }}
<script src="{{ 'fabric.min.js' | asset_url }}" defer></script>
<script src="{{ 'configurateur.js' | asset_url }}" defer></script>
<script src="{{ 'configurateur-phase1.js' | asset_url }}" defer></script>
<script src="{{ 'configurateur-phase2.js' | asset_url }}" defer></script>
<script src="{{ 'text-advanced-controls.js' | asset_url }}" defer></script>
<script src="{{ 'text-floating-actions.js' | asset_url }}" defer></script>
<script src="{{ 'product-color-changer.js' | asset_url }}" defer></script>
<script src="{{ 'history-manager.js' | asset_url }}" defer></script>
<script src="{{ 'preview-submit.js' | asset_url }}" defer></script>

<div class="configurateur-container" id="configurateur-app">
  
  {%- comment -%} ══════════════════════════════════════════════════════════════
    1. SÉLECTEUR DE PRODUIT
  ══════════════════════════════════════════════════════════════ {%- endcomment -%}
  <section class="configurateur-section configurateur-product-selector">
    <h1 class="configurateur-title">{{ section.settings.main_title | default: "Créez votre produit personnalisé" }}</h1>
    <p class="configurateur-description">{{ section.settings.description | default: "Sélectionnez un produit et uploadez votre design sur les différentes faces." }}</p>
    
    <div class="product-selector-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          {% assign product = block.settings.product %}
          {% if product %}
            {%- liquid
              assign front_image = ""
              assign back_image  = ""
              assign left_image  = ""
              assign right_image = ""

              assign front_image_val = product.metafields.custom.image_front.value
              assign back_image_val  = product.metafields.custom.image_back.value
              assign left_image_val  = product.metafields.custom.image_left.value
              assign right_image_val = product.metafields.custom.image_right.value

              if front_image_val != blank
                if front_image_val.preview_image
                  assign front_image = front_image_val | image_url: width: 1200
                else
                  assign front_image = front_image_val
                endif
              endif

              if back_image_val != blank
                if back_image_val.preview_image
                  assign back_image = back_image_val | image_url: width: 1200
                else
                  assign back_image = back_image_val
                endif
              endif

              if left_image_val != blank
                if left_image_val.preview_image
                  assign left_image = left_image_val | image_url: width: 1200
                else
                  assign left_image = left_image_val
                endif
              endif

              if right_image_val != blank
                if right_image_val.preview_image
                  assign right_image = right_image_val | image_url: width: 1200
                else
                  assign right_image = right_image_val
                endif
              endif
            -%}

            <div class="product-card" 
                 data-product-id="{{ product.id }}"
                 data-product-title="{{ product.title | escape }}"
                 data-view-front="{{ front_image }}"
                 data-view-back="{{ back_image }}"
                 data-view-left="{{ left_image }}"
                 data-view-right="{{ right_image }}"
                 data-editable-zones="{{ product.metafields.custom.editable_zones | escape }}">
              
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 300 }}" 
                     alt="{{ product.title }}"
                     width="300"
                     height="300"
                     class="product-card-image"
                     loading="lazy">
              {% endif %}
              
              <h3 class="product-card-title">{{ product.title }}</h3>
              
              {% if product.description %}
                <p class="product-card-description">{{ product.description | strip_html | truncate: 80 }}</p>
              {% endif %}
              
              <button class="btn btn-select-product" type="button">
                Personnaliser ce produit
              </button>
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </section>

  {%- comment -%} ══════════════════════════════════════════════════════════════
    2. INTERFACE DE CUSTOMISATION (Masquée par défaut)
  ══════════════════════════════════════════════════════════════ {%- endcomment -%}
  <section class="configurateur-section configurateur-editor" id="editor-section" style="display: none;">
    

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    
    <title>{{ 'gift_cards.issued.title' | t }}</title>

    <meta name="description" content="{{ 'gift_cards.issued.subtext' | t }}">

    {{ content_for_header }}

    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        margin: 0;
        padding: 20px;
        background: #f8f8f8;
      }
      
      .gift-card-wrapper {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }
      
      .gift-card-code {
        font-size: 24px;
        font-weight: bold;
        padding: 20px;
        background: #f0f0f0;
        border-radius: 4px;
        text-align: center;
        margin: 20px 0;
        letter-spacing: 2px;
      }
      
      .gift-card-qr {
        text-align: center;
        margin: 20px 0;
      }
      
      .gift-card-amount {
        font-size: 32px;
        font-weight: bold;
        color: #333;
        text-align: center;
        margin: 20px 0;
      }
      
      .gift-card-balance {
        text-align: center;
        color: #666;
        margin: 10px 0;
      }
      
      .gift-card-actions {
        text-align: center;
        margin: 30px 0;
      }
      
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background: #000;
        color: #fff;
        text-decoration: none;
        border-radius: 4px;
        margin: 5px;
      }
      
      .btn:hover {
        background: #333;
      }
    </style>
  </head>
  
  <body>
    <div class="gift-card-wrapper">
      <h1 style="text-align: center;">{{ 'gift_cards.issued.title' | t }}</h1>
      
      <p style="text-align: center; color: #666;">
        {{ 'gift_cards.issued.subtext' | t }}
      </p>

      {% if gift_card.expired or gift_card.enabled != true %}
        <p style="text-align: center; color: red;">
          {% if gift_card.expired %}
            {{ 'gift_cards.issued.expired' | t }}
          {% else %}
            {{ 'gift_cards.issued.disabled' | t }}
          {% endif %}
        </p>
      {% endif %}

      <div class="gift-card-amount">
        {% if gift_card.balance != gift_card.initial_value %}
          {{ gift_card.balance | money }} {{ 'gift_cards.issued.remaining_html' | t }}
        {% else %}
          {{ gift_card.initial_value | money }}
        {% endif %}
      </div>

      {% if gift_card.balance != gift_card.initial_value %}
        <p class="gift-card-balance">
          {{ 'gift_cards.issued.initial_value' | t: value: gift_card.initial_value | money }}
        </p>
      {% endif %}

      <div class="gift-card-code">
        {{ gift_card.code | format_code }}
      </div>

      <div class="gift-card-qr">
        {{ gift_card.qr_image | img_tag: gift_card.qr_identifier }}
      </div>

      {% if gift_card.pass_url %}
        <div class="gift-card-actions">
          <a href="{{ gift_card.pass_url }}" class="btn">
            {{ 'gift_cards.issued.add_to_apple_wallet' | t }}
          </a>
        </div>
      {% endif %}

      <div class="gift-card-actions">
        <a href="{{ shop.url }}" class="btn">
          {{ 'gift_cards.issued.shop_link' | t }}
        </a>
        <button onclick="window.print()" class="btn">
          {{ 'gift_cards.issued.print_gift_card' | t }}
        </button>
      </div>

      <p style="text-align: center; color: #999; font-size: 12px; margin-top: 40px;">
        {{ 'gift_cards.issued.redeem' | t }}
      </p>
    </div>
  </body>
</html>
